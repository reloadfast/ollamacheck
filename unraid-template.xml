<?xml version="1.0" ?>
<Container version="2">
  <Name>OllamaCheck</Name>
  <Repository>ollamacheck/ollamacheck:latest</Repository>
  <Registry>https://registry.hub.docker.com/u/ollamacheck/ollamacheck/</Registry>
  <Network>bridge</Network>
  <MyIP />
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/ollamacheck/ollamacheck/issues</Support>
  <Project>https://github.com/ollamacheck/ollamacheck</Project>
  <Overview>OllamaCheck is a web utility that tracks and ranks Ollama models suited for 40GB GPU environments and AI coding agents.</Overview>
  <Category>Tools:</Category>
  <WebUI>http://[IP]:[PORT:5173]</WebUI>
  <TemplateURL>https://github.com/ollamacheck/ollamacheck</TemplateURL>
  <Icon>https://raw.githubusercontent.com/ollamacheck/ollamacheck/main/docs/icon.png</Icon>
  <ExtraParams />
  <PostArgs />
  <CPUset />
  <DateInstalled>1700000000</DateInstalled>
  <DonateText>If you find this application useful, consider supporting the project.</DonateText>
  <DonateLink>https://github.com/sponsors/ollamacheck</DonateLink>
  <Description>OllamaCheck is a web utility that tracks and ranks Ollama models suited for 40GB GPU environments and AI coding agents (Claude Code, OpenCode, Codex CLI, etc.). It provides daily-updated ranked list of Ollama models that fit within 40GB VRAM, are strong candidates for code agent use, and show the correct pull command.</Description>

  <Config Name="WebUI Port" Target="5173" Default="5173" Mode="tcp" Description="Port for the web UI" Type="Port" Display="always" Required="true" Mask="false" />
  <Config Name="API Port" Target="3001" Default="3001" Mode="tcp" Description="Port for the API server" Type="Port" Display="always" Required="true" Mask="false" />

  <Config Name="Data Directory" Target="/app/data" Default="/mnt/cache/appdata/ollamacheck" Mode="rw" Description="Directory for database storage" Type="Path" Display="always" Required="true" Mask="false" />

  <Config Name="Timezone" Target="TZ" Default="Europe/Madrid" Mode="rw" Description="Timezone setting" Type="Variable" Display="always" Required="false" Mask="false" />

  <!-- Environment variables for the API service -->
  <Config Name="Database URL" Target="DATABASE_URL" Default="file:./data/db.sqlite" Mode="rw" Description="Database connection string" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="API Port" Target="API_PORT" Default="3001" Mode="rw" Description="API server port" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="API Host" Target="API_HOST" Default="localhost" Mode="rw" Description="API server host" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="API Origin" Target="API_ORIGIN" Default="http://localhost:5173" Mode="rw" Description="Allowed API origin" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Scrape Interval" Target="SCRAPE_INTERVAL" Default="0 0 * * *" Mode="rw" Description="Cron schedule for scraping" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Node Environment" Target="NODE_ENV" Default="development" Mode="rw" Description="Node.js environment" Type="Variable" Display="always" Required="false" Mask="false" />
</Container>